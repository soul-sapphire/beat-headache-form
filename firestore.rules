rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
// Until deployed, the Firebase console / emulator rules apply.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn()
        && userDoc().data.role == 'admin'
        && userDoc().data.approved == true
        && userDoc().data.status == 'approved';
    }

    function isApprovedDoctor() {
      return isSignedIn()
        && userDoc().data.role == 'doctor'
        && userDoc().data.approved == true
        && userDoc().data.status == 'approved';
    }

    function isApprovedDoctorOrAdmin() {
      return isAdmin() || isApprovedDoctor();
    }

    // Use resource.data for patient collection reads/lists (required for secure queries).
    function isLinkedToPatientResource() {
      return request.auth.uid in resource.data.linkedDoctorUids;
    }

    // Parent lookup for subcollections under patients/{patientCode}/...
    function isLinkedToPatientId(patientCode) {
      return request.auth.uid in get(/databases/$(database)/documents/patients/$(patientCode)).data.linkedDoctorUids;
    }

    // users/{uid}
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == uid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'approved', 'status']));
    }

    // counters/patients — sequence for patient IDs
    match /counters/{counterId} {
      allow read, write: if isApprovedDoctorOrAdmin();
    }

    // patients/{patientCode}
    // TODO(production): add doctorPatients/{doctorUid}/patients/{patientCode} index for stricter list rules.
    match /patients/{patientCode} {
      // Single-document read (exact patient ID)
      allow get: if isAdmin() || (isApprovedDoctor() && isLinkedToPatientResource());

      // Collection queries (autocomplete prefix / linkedDoctorUids array-contains)
      // Doctor queries MUST use: where("linkedDoctorUids", "array-contains", request.auth.uid)
      // Admin may list/range query all patients.
      allow list: if isAdmin() || (isApprovedDoctor() && isLinkedToPatientResource());

      allow create: if isApprovedDoctorOrAdmin();
      allow update: if isAdmin() || (isApprovedDoctor() && isLinkedToPatientResource());

      match /encounters/{encounterId} {
        allow read: if isAdmin() || (isApprovedDoctor() && isLinkedToPatientId(patientCode));
        allow create: if isApprovedDoctorOrAdmin();
        allow update: if isAdmin() || (isApprovedDoctor() && isLinkedToPatientId(patientCode));
      }

      match /accessLogs/{logId} {
        allow read: if isAdmin();
        allow create: if isApprovedDoctorOrAdmin();
      }
    }

    // researchDataset/data/rows/{rowId} — admin read; doctors create on encounter save
    match /researchDataset/data/rows/{rowId} {
      allow read: if isAdmin();
      allow create: if isApprovedDoctorOrAdmin();
      allow update, delete: if isAdmin();
    }

    match /researchDataset/data {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }
  }
}
